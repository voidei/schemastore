{
  "registries": {
    "github-packages": {
      "scope": 42,
      "token": "${{ secrets.GH_PACKAGES_PAT }}",
      "type": "npm-registry",
      "url": "https://npm.pkg.github.com"
    }
  },
  "updates": [
    {
      "directory": "/",
      "package-ecosystem": "npm",
      "registries": ["github-packages"],
      "schedule": {
        "interval": "daily"
      }
    }
  ],
  "version": 2
}
