{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://json.schemastore.org/github-prompt.json",
  "$comment": "https://docs.github.com/en/github-models/use-github-models/storing-prompts-in-github-repositories",
  "title": "GitHub Models prompt file",
  "description": "YAML prompt files used with GitHub Models (.prompt.yml / .prompt.yaml)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the prompt",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Short description of what the prompt does"
    },
    "model": {
      "type": "string",
      "description": "Model identifier (for example openai/gpt-4o-mini)",
      "minLength": 1
    },
    "modelParameters": {
      "type": "object",
      "description": "Model parameters such as temperature",
      "additionalProperties": true,
      "properties": {
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "messages": {
      "type": "array",
      "description": "Prompt templates with simple {{variable}} placeholders",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1,
            "description": "Message role (commonly system, user, or assistant)"
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "testData": {
      "type": "array",
      "description": "Sample inputs and expected outputs for evaluation",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "input": {},
          "expected": {}
        }
      }
    },
    "evaluators": {
      "type": "array",
      "description": "Evaluator definitions for prompt tests",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "string": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "startsWith": {
                "type": "string"
              },
              "endsWith": {
                "type": "string"
              },
              "contains": {
                "type": "string"
              },
              "equals": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": ["messages"]
}
