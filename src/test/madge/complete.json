{
  "$schema": "https://json.schemastore.org/madge.json",
  "backgroundColor": "transparent",
  "baseDir": "./src",
  "cyclicNodeColor": "tomato",
  "dependencyFilter": false,
  "detectiveOptions": {
    "customParser": {
      "customOption": true
    },
    "es6": {
      "mixedImports": true,
      "skipTypeImports": true
    },
    "ts": {
      "mixedImports": true,
      "skipAsyncImports": true,
      "skipTypeImports": false
    },
    "tsx": {
      "skipAsyncImports": true
    }
  },
  "edgeColor": "gray50",
  "excludeRegExp": ["^dist/", ".*\\.test\\.[jt]sx?$"],
  "fileExtensions": ["js", "jsx", "ts", "tsx"],
  "fontName": "Inter",
  "fontSize": "12px",
  "graphVizOptions": {
    "E": {
      "penwidth": 2
    },
    "G": {
      "overlap": false,
      "splines": "ortho"
    },
    "N": {
      "margin": "0.1"
    }
  },
  "graphVizPath": "C:/Program Files/Graphviz/bin",
  "includeNpm": true,
  "layout": "dot",
  "noDependencyColor": "gray90",
  "nodeColor": "steelblue",
  "nodeShape": "ellipse",
  "nodeStyle": "rounded,filled",
  "rankdir": "RL",
  "requireConfig": "./require.config.js",
  "tsConfig": {
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "@app/*": ["src/*"]
      }
    }
  },
  "webpackConfig": "./webpack.config.js"
}
