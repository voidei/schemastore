{
  "debug": false,
  "exit-code": 1,
  "follow-symlinks": true,
  "followSymlinks": true,
  "format": ["astro", "cfscript", "svelte", "toml", "vue", "zig"],
  "formats": "typescript",
  "formats-exts": ["javascript:es,es6"],
  "formats-names": "makefile:Makefile,GNUmakefile",
  "formatsExts": "javascript:es,es6;dart:dt",
  "formatsNames": {
    "docker": "Dockerfile",
    "makefile": ["Makefile", "GNUmakefile"]
  },
  "ignore-case": true,
  "ignore-pattern": ["//\\s*cpd-disable"],
  "max-lines": 1000,
  "max-size": "1m",
  "min-lines": 5,
  "min-tokens": 50,
  "no-colors": true,
  "no-gitignore": false,
  "no-tips": true,
  "noColors": true,
  "noGitignore": false,
  "noTips": true,
  "path": ["./src", "./packages"],
  "reporters": [
    "console",
    "consoleFull",
    "console-full",
    "full",
    "json",
    "html",
    "markdown",
    "badge",
    "sarif",
    "ai",
    "xcode",
    "threshold",
    "silent"
  ],
  "skip-local": false,
  "storePath": ".jscpd-cache"
}
