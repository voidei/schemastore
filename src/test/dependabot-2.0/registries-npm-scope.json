{
  "registries": {
    "github-packages-multi-scope": {
      "scope": ["@my-org", "@my-other-org"],
      "token": "${{ secrets.GH_PACKAGES_PAT }}",
      "type": "npm-registry",
      "url": "https://npm.pkg.github.com"
    },
    "github-packages-single-scope": {
      "scope": "@my-org",
      "token": "${{ secrets.GH_PACKAGES_PAT }}",
      "type": "npm-registry",
      "url": "https://npm.pkg.github.com"
    }
  },
  "updates": [
    {
      "directory": "/",
      "package-ecosystem": "npm",
      "registries": ["github-packages-single-scope"],
      "schedule": {
        "interval": "daily"
      }
    }
  ],
  "version": 2
}
